# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Admin Panel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
# Use "stderr" on Vercel so logs appear in the Vercel dashboard
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Local: SQLite    |    Production: use Neon / Railway / Supabase (PostgreSQL or MySQL)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ── Sessions / Cache / Queue ─────────────────────────────────────────────────
# "database" works for both local and Vercel serverless
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Filesystem ───────────────────────────────────────────────────────────────
# Use "s3" on Vercel (local disk is ephemeral /tmp — files are lost between requests)
FILESYSTEM_DISK=local

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS S3 (required for persistent file uploads on Vercel) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# VERCEL PRODUCTION — copy these to your Vercel project environment variables
# =============================================================================
#
# APP_NAME="Admin Panel"
# APP_ENV=production
# APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
# APP_DEBUG=false
# APP_URL=https://your-app.vercel.app
#
# LOG_CHANNEL=stderr
#
# DB_CONNECTION=mysql
# DB_HOST=your-db-host.neon.tech          # or Railway / Supabase
# DB_PORT=3306
# DB_DATABASE=your_database
# DB_USERNAME=your_username
# DB_PASSWORD=your_password
#
# SESSION_DRIVER=database
# CACHE_STORE=database
# QUEUE_CONNECTION=sync                    # jobs run inline on Vercel
#
# FILESYSTEM_DISK=s3                       # use S3 for avatar uploads
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=your-bucket
