Homestead.json
Homestead.yaml

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: /vendor is intentionally NOT excluded.
# Vercel's build environment does not have PHP or Composer, so vendor/ must
# be committed for GitHub → Vercel deployments to work.
# Run: composer install --no-dev --optimize-autoloader  before committing.
