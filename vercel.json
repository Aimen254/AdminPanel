{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/(css|js|assets|fonts|images|favicon\\.ico|robots\\.txt)(.*)",
      "dest": "/public/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
